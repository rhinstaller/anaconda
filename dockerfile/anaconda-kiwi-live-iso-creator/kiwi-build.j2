#!/usr/bin/env bash
set -euo pipefail

# --- Simple logging -----------------------------------------------------------
log()  { echo "[$(date -u +%H:%M:%S)] $*" >&2; }
warn() { echo "[$(date -u +%H:%M:%S)] WARNING: $*" >&2; }
err()  { echo "[$(date -u +%H:%M:%S)] ERROR:   $*" >&2; }

# --- Relax SELinux on the build host (per KIWI docs) -------------------------
if [ -e "/sys/fs/selinux/enforce" ]; then
  selinux_enforcing="$(cat /sys/fs/selinux/enforce 2>/dev/null || echo 0)"
  if [ "$selinux_enforcing" = "1" ]; then
    log "Disabling SELinux enforcement for KIWI build..."
    setenforce 0 2>/dev/null || true
  fi
fi

# --- Paths inside the container ----------------------------------------------
WORK_DIR=/work
REPOS_DIR=/repos

FEDORA_KIWI_DESC_URL="${FEDORA_KIWI_DESC_URL:-https://pagure.io/fedora-kiwi-descriptions.git}"

FEDORA_KIWI_DESC_DIR="$(mktemp -d /tmp/fedora-kiwi-descriptions.XXXXXX)"
DESC_TMP="$(mktemp -d /tmp/kiwi-desc.XXXXXX)"

cleanup() {
  rm -rf "${FEDORA_KIWI_DESC_DIR}" "${DESC_TMP}" 2>/dev/null || true
}
trap cleanup EXIT

# --- Required tools -----------------------------------------------------------
command -v createrepo_c >/dev/null
command -v kiwi-ng >/dev/null
command -v git >/dev/null

# --- Local repository with Anaconda RPMs -------------------------------------
mkdir -p "${REPOS_DIR}/anaconda-local"

if compgen -G "/anaconda-rpms/*.rpm" > /dev/null; then
  log "Copying Anaconda RPMs to ${REPOS_DIR}/anaconda-local..."
  cp -a /anaconda-rpms/*.rpm "${REPOS_DIR}/anaconda-local/"
else
  warn "No /anaconda-rpms/*.rpm found, anaconda-local repo will be empty."
fi

log "Creating local rpm-md repo at ${REPOS_DIR}/anaconda-local..."
createrepo_c "${REPOS_DIR}/anaconda-local"

# --- Map CI_TAG to fedora-kiwi-descriptions branch and KIWI file -------------
: "${CI_TAG:=fedora-rawhide}"

case "${CI_TAG}" in
  fedora-rawhide)
    FEDORA_KIWI_DESC_BRANCH="rawhide"
    KIWI_FILENAME="Fedora.kiwi"
    ;;
  fedora-el|fedora-eln)
    FEDORA_KIWI_DESC_BRANCH="rawhide"
    KIWI_FILENAME="Fedora-ELN.kiwi"
    ;;
  fedora-*)
    VERSION="${CI_TAG#fedora-}"
    FEDORA_KIWI_DESC_BRANCH="f${VERSION}"
    KIWI_FILENAME="Fedora.kiwi"
    ;;
  *)
    warn "Unknown CI_TAG '${CI_TAG}', using 'rawhide' and Fedora.kiwi."
    FEDORA_KIWI_DESC_BRANCH="rawhide"
    KIWI_FILENAME="Fedora.kiwi"
    ;;
esac


log "Using branch='${FEDORA_KIWI_DESC_BRANCH}', KIWI='${KIWI_FILENAME}', CI_TAG='${CI_TAG}'"

# --- Clone fedora-kiwi-descriptions ------------------------------------------
log "Cloning ${FEDORA_KIWI_DESC_URL} (branch ${FEDORA_KIWI_DESC_BRANCH})..."
git clone --depth 1 --branch "${FEDORA_KIWI_DESC_BRANCH}" \
  "${FEDORA_KIWI_DESC_URL}" "${FEDORA_KIWI_DESC_DIR}" 2>&1 || {
    err "Failed to clone branch '${FEDORA_KIWI_DESC_BRANCH}' from ${FEDORA_KIWI_DESC_URL}"
    exit 1
  }

# --- Locate KIWI description file --------------------------------------------
KIWI_FILE="$(find "${FEDORA_KIWI_DESC_DIR}" -maxdepth 4 -name "${KIWI_FILENAME}" -type f | head -n1 || true)"

if [ -z "${KIWI_FILE}" ]; then
  err "${KIWI_FILENAME} not found in ${FEDORA_KIWI_DESC_DIR} (branch ${FEDORA_KIWI_DESC_BRANCH})"
  warn "Available KIWI files (first 10):"
  find "${FEDORA_KIWI_DESC_DIR}" -maxdepth 5 -name "*.kiwi" -type f | head -10 >&2 || true
  exit 1
fi

KIWI_BASENAME="$(basename "${KIWI_FILE}")"
KIWI_DIR="$(dirname "${KIWI_FILE}")"

log "Using KIWI description: ${KIWI_FILE}"

# --- Copy KIWI description to working directory ------------------------------
cp -a "${KIWI_DIR}/." "${DESC_TMP}/"

if [ ! -f "${DESC_TMP}/${KIWI_BASENAME}" ]; then
  cp "${KIWI_FILE}" "${DESC_TMP}/${KIWI_BASENAME}"
fi



# --- DNF configuration: allow downgrades to older RPMs -----------------------
mkdir -p /etc/dnf
cat > /etc/dnf/dnf.conf <<'EOF'
[main]
best=False
allow_downgrade=True
EOF

# --- Profile helpers ----------------------------------------------------------
profile_exists() {
  local name="$1"
  find "${DESC_TMP}" -name "*.xml" -type f -exec \
    grep -q "<profile[^>]*name=[\"']${name}[\"']" {} \; 2>/dev/null
}

# --- Map FEDORA_VARIANT to KIWI profile --------------------------------------
# Supported variants: Workstation (default), KDE, Xfce, Cinnamon, MATE, LXDE, LXQt, 
#                     Sway, Budgie, SoaS, i3, MiracleWM, COSMIC, Phosh
log "Resolving KIWI profile..."

# Map FEDORA_VARIANT env variable to profile name (default: Workstation)
# Handle both unset and empty string
FEDORA_VARIANT="${FEDORA_VARIANT:-Workstation}"
if [ -z "${FEDORA_VARIANT}" ]; then
  FEDORA_VARIANT="Workstation"
fi
KIWI_PROFILE="${KIWI_PROFILE:-}"

# If KIWI_PROFILE not set, derive from FEDORA_VARIANT
log "FEDORA_VARIANT='${FEDORA_VARIANT}', KIWI_PROFILE='${KIWI_PROFILE}'"
if [ -z "${KIWI_PROFILE}" ]; then
  log "Deriving KIWI profile from FEDORA_VARIANT..."
  case "${FEDORA_VARIANT}" in
    Workstation)  KIWI_PROFILE="Workstation-Live" ;;
    KDE)          KIWI_PROFILE="KDE-Desktop-Live" ;;
    Xfce)         KIWI_PROFILE="Xfce-Live" ;;
    Cinnamon)     KIWI_PROFILE="Cinnamon-Live" ;;
    MATE|Compiz)  KIWI_PROFILE="MATE_Compiz-Live" ;;
    LXDE)         KIWI_PROFILE="LXDE-Live" ;;
    LXQt)         KIWI_PROFILE="LXQt-Live" ;;
    Sway)         KIWI_PROFILE="Sway-Live" ;;
    Budgie)       KIWI_PROFILE="Budgie-Live" ;;
    SoaS)         KIWI_PROFILE="SoaS-Live" ;;
    i3)           KIWI_PROFILE="i3-Live" ;;
    MiracleWM)    KIWI_PROFILE="MiracleWM-Live" ;;
    COSMIC)       KIWI_PROFILE="COSMIC-Live" ;;
    Phosh)        KIWI_PROFILE="Phosh-Live" ;;
    *)            
      warn "Unknown FEDORA_VARIANT='${FEDORA_VARIANT}', defaulting to Workstation-Live"
      KIWI_PROFILE="Workstation-Live"
      ;;
  esac
fi

# Verify profile exists
if ! profile_exists "${KIWI_PROFILE}"; then
  warn "Profile '${KIWI_PROFILE}' not found, auto-detecting..."
  # Fallback: first Live profile found
  CANDIDATE="$(find "${DESC_TMP}" -name "*.xml" -type f -exec grep '<profile' {} \; 2>/dev/null \
    | grep -i 'Live' | head -1 \
    | sed -n 's/.*name=["'\'']\([^"'\'']*\)["'\''].*/\1/p' || true)"
  if [ -n "${CANDIDATE}" ]; then
    KIWI_PROFILE="${CANDIDATE}"
    log "Auto-detected profile: ${KIWI_PROFILE}"
  else
    err "No Live profile found in KIWI description"
    warn "Available profiles (first 10):"
    find "${DESC_TMP}" -name "*.xml" -type f -exec grep '<profile.*name=' {} \; 2>/dev/null | head -10 >&2 || true
    exit 1
  fi
fi

log "Using KIWI profile: ${KIWI_PROFILE} (variant: ${FEDORA_VARIANT})"

# --- Build the image ---------------------------------------------------------
mkdir -p "${WORK_DIR}"

log "Starting KIWI build..."
if ! kiwi-ng --debug \
  --shared-cache-dir=/var/cache/kiwi \
  --type=iso \
  --profile="${KIWI_PROFILE}" \
  --kiwi-file="${KIWI_BASENAME}" \
  system build \
  --add-repo="/repos/anaconda-local,rpm-md,anaconda-local,10" \
  --description="${DESC_TMP}" \
  --target-dir="${WORK_DIR}"; then
  rc=$?
  err "KIWI build failed with exit code ${rc}"
  exit "${rc}"
fi

# --- Copy resulting ISO to /images -------------------------------------------
ISO_FILE="$(find "${WORK_DIR}" -maxdepth 1 -type f -name "*.iso" | head -n1 || true)"

# Determine output ISO name based on variant
OUTPUT_ISO_NAME="Fedora-${FEDORA_VARIANT}.iso"

if [ -n "${ISO_FILE}" ] && [ -f "${ISO_FILE}" ]; then
  log "Copying resulting ISO ${ISO_FILE} to /images/${OUTPUT_ISO_NAME}..."
  cp -L "${ISO_FILE}" "/images/${OUTPUT_ISO_NAME}"
  chown -R --reference=/anaconda-rpms /images 2>/dev/null || true
  log "ISO written to /images/${OUTPUT_ISO_NAME}"
else
  err "No ISO produced in ${WORK_DIR}"
  ls -la "${WORK_DIR}" >&2 || true
  exit 2
fi
